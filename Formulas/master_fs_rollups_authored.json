{
  "description": "AUTHORED roll-up formulas for the master FS. Human-authored (Claude, for Sabahat/Abhishek review) against the real AlJazira + SAAB face structure. AI never authors these — it maps leaves only. Engine computes them deterministically.",
  "sign_convention": "Amounts use the TB's native sign: income positive, expenses/zakat/tax stored NEGATIVE. Net-lines therefore use '+' on an expense whose stored value is already negative. If a client TB stores expenses as POSITIVE, the per-client mapping must record that and the signs flip — flag at confirm, do NOT silently assume.",
  "rules": {
    "kinds": "leaf=populated by mapped TB accounts; net=income-minus-expense face line; subtotal=intermediate roll-up; total=spine total (always renders).",
    "render": "spine totals always render; net/subtotal render iff >=1 component present; empty intermediates hide (same as empty leaves).",
    "derive_order": "topological — net-lines first, then subtotals that consume them, then spine totals; a total may reference another total (e.g. Total L&E = Total liabilities + Total equity).",
    "orphan_guard": "every populated leaf must appear in exactly one section total's component closure; assert no populated leaf is missing from its section total.",
    "balance_check": "Total assets vs Total liabilities and equity; mismatch -> non-blocking finding showing the difference, never auto-corrected."
  },
  "must_add_to_seed": [
    "bs_total_assets",
    "bs_total_liabilities",
    "bs_total_equity",
    "bs_total_liab_equity"
  ],
  "rollups": {
